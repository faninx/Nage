# Build context exclusions
node_modules
.next
.turbo
.turbo-cache
.pnpm-store

# Runtime data (用 volume 挂载)
data
backups
public/uploads
public/uploads/**

# 环境配置（用 env_file 注入）
.env
.env.local
.env.*.local

# 仓库元数据
.git
.gitignore
.gitattributes

# 文档（运行时不需要）
README.md
DEPLOY.md
PRD.md
CLAUDE.md

# Claude / IDE 配置
.claude
.cursor
.vscode
.idea

# 测试脚本（容器里不跑 E2E）
scripts/test-*.ts
scripts/test-*.mjs
scripts/test-*.js
scripts/loader-hook.mjs

# 杂项
*.log
.DS_Store
Thumbs.db
.eslintcache
