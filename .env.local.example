# 纳格（Nage）环境变量模板
# 复制本文件为 .env.local（开发）或 .env（生产部署）并填入真实值

# 管理员账号（首次启动时自动创建）
# 若留空，会自动生成临时 admin 账号和随机密码，控制台会输出
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

# JWT 签名密钥（最少 32 字节）
# 若留空，首次启动会随机生成并写回 .env.local
JWT_SECRET=

# SQLite 数据库文件路径（默认 ./data/nage.db）
# DATABASE_URL=./data/nage.db

# ─── 反向代理 ───
# Nage 自身只听 :3000，反代由你自己解决（Caddy / Nginx / Cloudflare Tunnel 任选）
# 参考配置见 docs/examples/，没有环境变量需要配。
# v1.0.0 的 ACME_EMAIL 已废弃（v1.0.1 起 Caddy 不再集成）

# 应用监听端口（贯通到 compose 端口映射 + 容器内 PORT 环境变量）
# 默认 3000；改成 8080 时，反代也要指向 127.0.0.1:8080
# APP_PORT=3000