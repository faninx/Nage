# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# 但要保留 env 模板（让人知道可以配哪些变量）
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# nage runtime data
# /data 包含 sqlite DB（nage.db）+ uploads（M10 起移到 data/ 防 dev 模式泄露未鉴权图）
/data
# 旧路径已弃用（uploads 移到 data/uploads），保留这一行防老 git 历史里有遗留
/public/uploads/*


# claude code (per-developer)
/.claude/

# dev-only debug scripts
/scripts/debug-*.mjs
/scripts/loader-hook.mjs

# PWA build artifacts (next-pwa 生成，每次 build 内容不同)
# 保留 public/icons/ 和 public/manifest.json（手写 / 重新生成）
# 不保留 public/sw.js（workbox 生成的 service worker，含 precache hash）
# 不保留 public/workbox-*.js / public/swe-worker-*.js（workbox runtime）
/public/sw.js
/public/swe-worker-*.js
/public/workbox-*.js
/public/workbox-*.js.map
/public/swe-worker-*.js.map
